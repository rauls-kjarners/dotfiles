{
  "language_server.diagnostics_on_update": false,
  "language_server.diagnostics_on_save": false,
  "language_server.diagnostics_on_open": false,
  "language_server_phpstan.enabled": false,
  "language_server_php_cs_fixer.enabled": false,
  "language_server_worse_reflection.diagnostics.enable": false,
  "language_server_code_transform.import_globals": false,
  "symfony.enabled": true,
  "indexer.exclude_patterns": [
    "/vendor/**/Tests/**/*",
    "/vendor/**/tests/**/*",
    "/vendor/composer/**/*",
    "/var/log/**/*",
    "/var/data/**/*",
    "/var/test/**/*",
    "/var/dev/**/*",
    "/var/cache/*/*.php",
    "/var/cache/.phpunit.cache/**/*",
    "/var/cache/*/Container*/**/*",
    "/var/cache/*/twig/**/*",
    "/var/cache/*/translations/**/*",
    "/var/cache/*/jms_aop/**/*",
    "/var/cache/*/profiler/**/*",
    "/var/cache/*/pools/**/*",
    "/var/cache/*/doctrine/**/*",
    "/var/cache/prod/**/*",
    "/var/cache/test/**/*",
    "/build/**/*",
    "/public/bundles/**/*"
  ]
}
